+    # ── Recursive recovery: collapse + bare summary ──────────────────
+    # When normal compression (L1) is exhausted, these provide deeper
+    # fallback tiers before giving up entirely.  Claude Code uses a
+    # similar cascade: compress → collapse → bare summary.
+
+    def collapse(
+        self, messages: List[Dict[str, Any]],
+        system_message: Optional[Dict[str, Any]] = None,
+    ) -> List[Dict[str, Any]]:
+        """L2: Aggressive compression — keep only first 3 exchanges + last 8 messages.
+
+        Much more aggressive than ``compress()``: drops all middle turns instead
+        of summarizing them, then runs a lightweight prune pass to avoid sending
+        the full stripped middle section.  Still preserves the system prompt,
+        the very first exchange (task-defining), and the most recent context.
+
+        Returns the collapsed message list (no API call needed).
+        """
+        if not messages or len(messages) <= 15:
+            return messages
+
+        # Identify head messages: system prompt + first meaningful exchange
+        head = []
+        idx = 0
+        if messages and messages[0].get("role") == "system":
+            head.append(messages[0])
+            idx = 1
+        # Capture first ~3 non-system exchanges (up to 6 messages)
+        head_count = 0
+        while idx < len(messages) and head_count < 3:
+            head.append(messages[idx])
+            idx += 1
+            head_count += 1
+
+        # Tail: last 8 messages (or fewer if short)
+        tail_start = max(idx, len(messages) - 8)
+        tail = messages[tail_start:]
+
+        # Build collapsed list with a clear insertion marker
+        collapse_note = {
+            "role": "user",
+            "content": (
+                "[Context collapsed: intermediate turns removed to fit context window. "
+                f"{len(messages) - len(head) - len(tail)} messages were dropped. "
+                "Continue from the most recent context below.]"
+            ),
+        }
+        collapsed = head + [collapse_note] + tail
+
+        # Run a final prune pass on the collapsed list so any stale tool
+        # results in the tail get replaced with compact summaries.
+        collapsed, _ = self._prune_old_tool_results(
+            collapsed,
+            protect_tail_count=min(8, len(tail)),
+            protect_tail_tokens=self.tail_token_budget,
+        )
+        return collapsed
+
+    def bare_summary(
+        self, messages: List[Dict[str, Any]],
+    ) -> List[Dict[str, Any]]:
+        """L3: Last resort — replace all history with a single summary message.
+
+        Only the system prompt and a single user message remain.  The
+        summary is constructed from the most recent assistant message
+        (if any) or a generic fallback.  This is a desperate measure
+        for when even collapse is still too large.
+
+        Returns a 2-message list: [system, summary_user].
+        """
+        system = messages[0] if messages and messages[0].get("role") == "system" else None
+
+        # Try to extract the last meaningful assistant content
+        last_content = ""
+        for msg in reversed(messages):
+            if msg.get("role") == "assistant" and msg.get("content"):
+                content = msg["content"]
+                if isinstance(content, str) and len(content.strip()) > 20:
+                    last_content = content.strip()[:1500]
+                    break
+
+        summary = (
+            "[History collapsed due to context limits. Here is the last "
+            "meaningful assistant response for continuity:\n\n"
+            f"{last_content}\n\n"
+            "---\n"
+            "The conversation history has been fully stripped. Please "
+            "continue the task based on what you can infer from this summary "
+            "and the system prompt above.]"
+            if last_content else
+            "[History collapsed due to context limits. The conversation "
+            "history has been fully stripped. Please continue the task "
+            "based on the system prompt above. You may need to ask the "
+            "user to re-state their current goal.]"
+        )
+
+        result = []
+        if system:
+            result.append(system)
+        result.append({"role": "user", "content": summary})
+        return result
