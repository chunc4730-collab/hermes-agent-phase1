+# ─── Config File Lock ─────────────────────────────────────────────────────────
+
+
+@contextmanager
+def config_file_lock(config_path: Union[str, Path], timeout: float = 10.0):
+    """Prevent concurrent writes to *config_path* via fcntl advisory lock.
+
+    Gatekeeper for config.yaml writes by the gateway and CLI to avoid
+    interleaved read-modify-write races across processes.
+    """
+    import time
+
+    lock_path = Path(str(config_path) + ".lock")
+    lock_path.parent.mkdir(parents=True, exist_ok=True)
+
+    fd = os.open(str(lock_path), os.O_RDWR | os.O_CREAT, 0o600)
+    try:
+        deadline = time.monotonic() + max(0.0, timeout)
+        while True:
+            try:
+                fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
+                break
+            except (BlockingIOError, OSError):
+                if time.monotonic() >= deadline:
+                    logger.warning(
+                        "config_file_lock: timed out after %ss on %s — proceeding without lock",
+                        timeout, config_path,
+                    )
+                    break
+                time.sleep(0.05)
+        yield
+    finally:
+        fcntl.flock(fd, fcntl.LOCK_UN)
+        try:
+            os.close(fd)
+        except OSError:
+            pass
+
