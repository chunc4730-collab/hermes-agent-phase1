@@ -494,6 +494,20 @@ def init_agent(
     agent._budget_exhausted_injected = False
     agent._budget_grace_call = False
 
+    # ── Session FSM: state tracker for multi-agent coordination ──
+    # Thin wrapper around existing flags (_interrupt_requested, etc.).
+    # Queryable by parent agents via agent._session_state.snapshot().
+    from agent.session_state import SessionState
+    agent._session_state = SessionState(agent)
+
+    # ── Plan executor: recovery source + fork isolation ──
+    # Plans are persisted under ~/.hermes/plans/<slug>/ and can be
+    # resumed in independent fork sessions. This executor manages the
+    # lifecycle (create, resume, complete, fail).
+    from agent.plan_executor import PlanExecutor
+    agent._plan_executor = PlanExecutor(get_hermes_home())
+    agent._plan_resume_context = None  # set when resuming a plan
+
     # Activity tracking — updated on each API call, tool execution, and
     # stream chunk.  Used by the gateway timeout handler to report what the
     # agent was doing when it was killed, and by the "still working"
@@ -1016,6 +1030,14 @@ def init_agent(
     
     # Cached system prompt -- built once per session, only rebuilt on compression
     agent._cached_system_prompt: Optional[str] = None
+
+    # Background memory review cursor — tracks the message index of the last
+    # completed review so subsequent reviews only process new messages instead
+    # of re-scanning the entire conversation.  Defaults to 0 (start of convo).
+    agent._memory_review_cursor: int = 0
+    # Set to True when the main agent writes to memory during this session,
+    # suppressing the background memory review to avoid duplicate extraction.
+    agent._memory_written_by_main: bool = False
     
     # Filesystem checkpoint manager (transparent — not a tool)
     from tools.checkpoint_manager import CheckpointManager
