+"""
+Plan executor — lifecycle management for plan recovery + fork isolation.
+
+Layout under ~/.hermes/plans/<slug>/:
+  ├── manifest.json   — PlanManifest (metadata + lifecycle)
+  ├── plan.md          — the plan content (agent writes)
+  ├── state.json       — PlanExecutionState (runtime tracking)
+  └── .lock            — file lock for concurrent access
+
+Fork isolation: plan execution creates an INDEPENDENT child session.
+The parent session that created the plan is left untouched. The fork
+session gets its own session_id, messages, and tool state. The only
+link is through manifest.resume_from_session ↔ manifest.resume_to_session.
+
+Safety rules:
+  - Max 3 resumes per plan (prevent infinite loops)
+  - Only DRAFT or PAUSED plans can be resumed
+  - Only one session can execute a plan at a time (EXECUTING state)
+  - File lock prevents concurrent manifest writes
+"""
+
+from __future__ import annotations
+
+import fcntl
+import logging
+import os
+import time
+from pathlib import Path
+from typing import Optional
+
+from .plan_models import (
+    PlanManifest,
+    PlanExecutionState,
+    PlanResumeContext,
+    PlanState,
+    ForkMode,
+    StepState,
+)
+
+logger = logging.getLogger(__name__)
+
+# ── Constants ────────────────────────────────────────────────────────
+
+PLANS_DIR_NAME = "plans"
+MAX_RESUME_COUNT = 3
+
+# Minimal plan template injected when the agent needs to write a plan
+PLAN_TEMPLATE = """## Plan: {title}
+
+### Goal
+[What this plan aims to accomplish]
+
+### Context
+[Background information, constraints, relevant session history]
+
+### Steps
+1. [First step]
+2. [Second step]
+3. [Third step]
+
+### Notes
+[Additional notes, pitfalls, edge cases]
+"""
+
+
+# ── Helper ───────────────────────────────────────────────────────────
+
+
+def _get_plans_dir(hermes_home: str | Path) -> Path:
+    """Get or create the plans directory."""
+    p = Path(hermes_home) / PLANS_DIR_NAME
+    p.mkdir(parents=True, exist_ok=True)
+    return p
+
+
+def _next_slug(plans_dir: Path, base_slug: str) -> str:
+    """Resolve a slug, appending '-N' if a plan with that slug exists."""
+    candidate = base_slug
+    n = 1
+    while (plans_dir / candidate).exists():
+        candidate = f"{base_slug}-{n}"
+        n += 1
+    return candidate
+
+
+# ── PlanExecutor ─────────────────────────────────────────────────────
+
+
+class PlanExecutor:
+    """Manages plan lifecycle: create, resume, fork, complete, fail."""
+
+    def __init__(self, hermes_home: str | Path):
+        self._plans_dir = _get_plans_dir(hermes_home)
+
+    # ── Create ────────────────────────────────────────────────────
+
+    def create(
+        self,
+        slug: str,
+        title: str,
+        content: Optional[str] = None,
+        resume_from_session: Optional[str] = None,
+    ) -> PlanManifest:
+        """Create a new plan directory with manifest and plan.md."""
+        final_slug = _next_slug(self._plans_dir, slug)
+        plan_dir = self._plans_dir / final_slug
+        plan_dir.mkdir(parents=True, exist_ok=False)
+
+        manifest = PlanManifest(
+            slug=final_slug,
+            title=title,
+            resume_from_session=resume_from_session,
+        )
+
+        # Write plan.md
+        plan_content = content or PLAN_TEMPLATE.format(title=title)
+        (plan_dir / "plan.md").write_text(plan_content, encoding="utf-8")
+
+        # Write manifest
+        (plan_dir / "manifest.json").write_text(manifest.to_json(), encoding="utf-8")
+
+        # Write empty execution state
+        exec_state = PlanExecutionState()
+        (plan_dir / "state.json").write_text(exec_state.to_json(), encoding="utf-8")
+
+        logger.info("Created plan '%s' at %s", final_slug, plan_dir)
+        return manifest
+
+    # ── Resume ────────────────────────────────────────────────────
+
+    def resume(self, slug: str, session_id: str) -> Optional[PlanResumeContext]:
+        """Resume a plan, returning a context for injection into the agent.
+
+        Returns None if the plan cannot be resumed (missing, wrong state, etc.).
+        """
+        plan_dir = self._plans_dir / slug
+        if not plan_dir.is_dir():
+            logger.error("Plan '%s' not found at %s", slug, plan_dir)
+            return None
+
+        manifest = self._load_manifest(plan_dir)
+        if manifest is None:
+            return None
+
+        # Guard: only DRAFT or PAUSED can be resumed
+        if manifest.state not in (PlanState.DRAFT, PlanState.PAUSED):
+            logger.error("Plan '%s' is %s — cannot resume", slug, manifest.state.value)
+            return None
+
+        exec_state = self._load_exec_state(plan_dir)
+        if exec_state is None:
+            exec_state = PlanExecutionState()
+
+        # Guard: max resume count
+        if exec_state.resume_count >= MAX_RESUME_COUNT:
+            logger.error("Plan '%s' has been resumed %d times — max %d",
+                         slug, exec_state.resume_count, MAX_RESUME_COUNT)
+            return None
+
+        # Read plan content
+        plan_content = (plan_dir / manifest.plan_file).read_text(encoding="utf-8")
+
+        # Capture fork mode BEFORE mutating state to EXECUTING
+        fork_mode = ForkMode.RESUME if manifest.state == PlanState.PAUSED else ForkMode.FRESH
+
+        # Mark as executing
+        manifest.state = PlanState.EXECUTING
+        manifest.resume_to_session = session_id
+        manifest.updated_at = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
+        exec_state.resume_count += 1
+        exec_state.session_id = session_id
+
+        with _lock_plan_dir(plan_dir):
+            (plan_dir / "manifest.json").write_text(manifest.to_json(), encoding="utf-8")
+            (plan_dir / "state.json").write_text(exec_state.to_json(), encoding="utf-8")
+
+        logger.info("Resumed plan '%s' → session %s (resume #%d)",
+                     slug, session_id, exec_state.resume_count)
+
+        return PlanResumeContext(
+            manifest=manifest,
+            exec_state=exec_state,
+            plan_content=plan_content,
+            plan_dir=str(plan_dir),
+            fork_mode=fork_mode,
+        )
+
+    # ── Lifecycle ─────────────────────────────────────────────────
+
+    def mark_complete(self, slug: str) -> bool:
+        """Mark a plan as completed."""
+        return self._transition(slug, PlanState.COMPLETED)
+
+    def mark_failed(self, slug: str, error: str = "") -> bool:
+        """Mark a plan as failed with an error message."""
+        plan_dir = self._plans_dir / slug
+        if not plan_dir.is_dir():
+            return False
+
+        manifest = self._load_manifest(plan_dir)
+        exec_state = self._load_exec_state(plan_dir)
+        if manifest is None:
+            return False
+
+        manifest.state = PlanState.FAILED
+        manifest.updated_at = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
+
+        if exec_state:
+            exec_state.error = error
+
+        with _lock_plan_dir(plan_dir):
+            (plan_dir / "manifest.json").write_text(manifest.to_json(), encoding="utf-8")
+            if exec_state:
+                (plan_dir / "state.json").write_text(exec_state.to_json(), encoding="utf-8")
+
+        logger.info("Plan '%s' marked FAILED: %s", slug, error)
+        return True
+
+    def update_step(self, slug: str, step_index: int, status: str, error: str = "") -> bool:
+        """Update the execution state of a single step."""
+        plan_dir = self._plans_dir / slug
+        exec_state = self._load_exec_state(plan_dir)
+        if exec_state is None:
+            return False
+
+        if step_index >= len(exec_state.steps):
+            return False
+
+        exec_state.steps[step_index].status = status
+        exec_state.steps[step_index].error = error
+        exec_state.current_step = step_index
+
+        with _lock_plan_dir(plan_dir):
+            (plan_dir / "state.json").write_text(exec_state.to_json(), encoding="utf-8")
+
+        return True
+
+    # ── Query ─────────────────────────────────────────────────────
+
+    def list_plans(self, state: Optional[PlanState] = None) -> list[PlanManifest]:
+        """List all plans, optionally filtered by state."""
+        plans = []
+        for plan_dir in sorted(self._plans_dir.iterdir()):
+            if not plan_dir.is_dir():
+                continue
+            m = self._load_manifest(plan_dir)
+            if m is None:
+                continue
+            if state is not None and m.state != state:
+                continue
+            plans.append(m)
+        return plans
+
+    def get_plan(self, slug: str) -> Optional[PlanManifest]:
+        """Get a single plan by slug."""
+        plan_dir = self._plans_dir / slug
+        return self._load_manifest(plan_dir)
+
+    def get_content(self, slug: str) -> Optional[str]:
+        """Read the plan.md content."""
+        plan_dir = self._plans_dir / slug
+        manifest = self._load_manifest(plan_dir)
+        if manifest is None:
+            return None
+        plan_file = plan_dir / manifest.plan_file
+        if plan_file.exists():
+            return plan_file.read_text(encoding="utf-8")
+        return None
+
+    # ── Helpers ───────────────────────────────────────────────────
+
+    def _load_manifest(self, plan_dir: Path) -> Optional[PlanManifest]:
+        mf = plan_dir / "manifest.json"
+        if not mf.exists():
+            return None
+        try:
+            return PlanManifest.from_json(mf.read_text(encoding="utf-8"))
+        except Exception:
+            logger.exception("Failed to load manifest from %s", mf)
+            return None
+
+    def _load_exec_state(self, plan_dir: Path) -> Optional[PlanExecutionState]:
+        sf = plan_dir / "state.json"
+        if not sf.exists():
+            return None
+        try:
+            return PlanExecutionState.from_json(sf.read_text(encoding="utf-8"))
+        except Exception:
+            logger.exception("Failed to load state from %s", sf)
+            return None
+
+    def _transition(self, slug: str, new_state: PlanState) -> bool:
+        """Atomically transition a plan to a new state."""
+        plan_dir = self._plans_dir / slug
+        if not plan_dir.is_dir():
+            return False
+        manifest = self._load_manifest(plan_dir)
+        if manifest is None:
+            return False
+        manifest.state = new_state
+        manifest.updated_at = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
+        with _lock_plan_dir(plan_dir):
+            (plan_dir / "manifest.json").write_text(manifest.to_json(), encoding="utf-8")
+        logger.info("Plan '%s' → %s", slug, new_state.value)
+        return True
+
+
+# ── File locking ─────────────────────────────────────────────────────
+
+
+import contextlib
+
+
+@contextlib.contextmanager
+def _lock_plan_dir(plan_dir: Path):
+    """Exclusive file lock on a plan directory for safe concurrent writes."""
+    lockfile = plan_dir / ".lock"
+    fd = os.open(str(lockfile), os.O_CREAT | os.O_RDWR)
+    try:
+        fcntl.flock(fd, fcntl.LOCK_EX)
+        yield
+    finally:
+        fcntl.flock(fd, fcntl.LOCK_UN)
+        os.close(fd)
+
+
+# ── Plan prompt injection ─────────────────────────────────────────────
+
+
+def build_plan_prompt(context: PlanResumeContext) -> str:
+    """Build a system prompt injection for plan execution/resume.
+
+    Injected into the agent's system prompt when executing a plan.
+    """
+    lines = []
+
+    if context.fork_mode == ForkMode.RESUME:
+        lines.append("## RESUMING PLAN EXECUTION")
+        lines.append(f"You are resuming plan '{context.manifest.slug}': {context.manifest.title}")
+        if context.exec_state.error:
+            lines.append(f"Previous error: {context.exec_state.error}")
+    else:
+        lines.append("## PLAN EXECUTION MODE")
+        lines.append(f"You are executing plan '{context.manifest.slug}': {context.manifest.title}")
+        lines.append("Follow the plan below. Mark steps as done as you complete them.")
+        lines.append("If you hit a blocker, save progress and report the error.")
+
+    if context.exec_state.steps:
+        lines.append(f"\n### Current Progress (step {context.exec_state.current_step + 1}/{context.exec_state.total_steps})")
+        for step in context.exec_state.steps:
+            icon = {
+                "done": "✅",
+                "in_progress": "🔄",
+                "failed": "❌",
+                "skipped": "⏭️",
+                "pending": "⬜",
+            }.get(step.status, "⬜")
+            lines.append(f"  {icon} Step {step.index + 1}: {step.content}")
+
+    lines.append(f"\n### The Plan")
+    lines.append(context.plan_content)
+
+    lines.append("\n### Instructions")
+    lines.append("1. Work through the plan steps in order.")
+    lines.append("2. After completing each step, note it in your response.")
+    lines.append("3. If you cannot complete the plan, explain why and preserve partial progress.")
+    lines.append("4. When all steps are done, state 'PLAN COMPLETE'.")
+
+    return "\n".join(lines)
diff --git a/agent/plan_models.py b/agent/plan_models.py
new file mode 100644
index 000000000..65f8a6736
--- /dev/null
+++ b/agent/plan_models.py
@@ -0,0 +1,118 @@
+"""
+Plan recovery source + fork isolation — data models.
+
+Design constraints (from Claude Code plan system):
+  - Plans are named directories under ~/.hermes/plans/<slug>/
+  - manifest.json: metadata + lifecycle state
+  - plan.md: the plan content (markdown, agent writes it)
+  - state.json: runtime execution state (current step, sub-task states)
+  - .lock: file lock for concurrent access
+
+Slug rules: lowercase, kebab-case, max 64 chars. Auto-increment on conflict.
+Fork semantics: a plan execution creates an INDEPENDENT child session with its
+  own session_id. The manifest links back to the session that created the plan
+  and forward to the session that executed it.
+"""
+
+from __future__ import annotations
+
+import enum
+import json
+import os
+import time
+from dataclasses import dataclass, field, asdict
+from pathlib import Path
+from typing import Optional
+
+
+# ── Enums ────────────────────────────────────────────────────────────
+
+
+class PlanState(str, enum.Enum):
+    """Plan lifecycle states."""
+    DRAFT = "draft"           # plan.md exists, not yet executed
+    EXECUTING = "executing"   # a session is currently executing this plan
+    COMPLETED = "completed"   # execution finished successfully
+    FAILED = "failed"         # execution failed
+    PAUSED = "paused"         # paused mid-execution, awaiting resume
+
+
+class ForkMode(str, enum.Enum):
+    """How a plan session relates to its parent."""
+    FRESH = "fresh"           # brand new session for plan execution
+    RESUME = "resume"         # resuming a previously paused plan session
+
+
+# ── Data classes ─────────────────────────────────────────────────────
+
+
+@dataclass
+class StepState:
+    """Runtime state of a single plan step."""
+    index: int
+    content: str              # the step line from plan.md
+    status: str = "pending"   # pending | in_progress | done | skipped | failed
+    error: Optional[str] = None
+
+
+@dataclass
+class PlanManifest:
+    """On-disk manifest for a plan directory."""
+    slug: str
+    title: str
+    created_at: str = field(default_factory=lambda: time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()))
+    updated_at: str = field(default_factory=lambda: time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()))
+    state: PlanState = PlanState.DRAFT
+
+    # Session linkage (bidirectional)
+    resume_from_session: Optional[str] = None   # session that wrote this plan
+    resume_to_session: Optional[str] = None     # session that executed this plan
+
+    # Metadata
+    plan_file: str = "plan.md"
+    version: int = 1
+    tags: list[str] = field(default_factory=list)
+
+    def to_json(self) -> str:
+        d = asdict(self)
+        d["state"] = self.state.value
+        return json.dumps(d, indent=2, ensure_ascii=False)
+
+    @classmethod
+    def from_json(cls, s: str) -> "PlanManifest":
+        d = json.loads(s)
+        d["state"] = PlanState(d["state"])
+        return cls(**d)
+
+
+@dataclass
+class PlanExecutionState:
+    """Runtime execution state (state.json in plan directory)."""
+    current_step: int = 0
+    total_steps: int = 0
+    steps: list[StepState] = field(default_factory=list)
+    paused_at_step: Optional[int] = None
+    error: Optional[str] = None
+    session_id: Optional[str] = None  # the fork session executing this plan
+    resume_count: int = 0              # prevent infinite resume loops
+
+    def to_json(self) -> str:
+        d = asdict(self)
+        d["steps"] = [asdict(s) for s in self.steps]
+        return json.dumps(d, indent=2, ensure_ascii=False)
+
+    @classmethod
+    def from_json(cls, s: str) -> "PlanExecutionState":
+        d = json.loads(s)
+        d["steps"] = [StepState(**st) for st in d.get("steps", [])]
+        return cls(**d)
+
+
+@dataclass
+class PlanResumeContext:
+    """Injected into agent at runtime when resuming a plan."""
+    manifest: PlanManifest
+    exec_state: PlanExecutionState
+    plan_content: str
+    plan_dir: str          # absolute path to .hermes/plans/<slug>/
+    fork_mode: ForkMode = ForkMode.FRESH
