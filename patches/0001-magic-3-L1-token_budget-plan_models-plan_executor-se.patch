+++ b/agent/session_state.py
@@ -0,0 +1,234 @@
+"""
+Session state tracker for AIAgent lifecycle.
+
+Design: thin wrapper around existing flags. Adds:
+  - State enumeration (for child agent introspection via parent)
+  - Transition enforcement (for P2-1 plan fork safety)
+  - Status snapshot queryable from parent (improves multi-agent coordination)
+
+Not a full FSM replacement of existing flags — the flags still drive the
+main loop; this layer provides a single source of truth for external query.
+"""
+
+from __future__ import annotations
+
+import enum
+import threading
+from typing import Optional
+
+
+class AgentState(enum.Enum):
+    """AIAgent lifecycle states."""
+
+    IDLE = "idle"              # Initialized but not yet running
+    RUNNING = "running"        # Actively processing in main loop
+    WAITING_TOOLS = "waiting_tools"  # Tool calls executing
+    COMPRESSING = "compressing"      # Context compression in progress
+    WAITING_USER = "waiting_user"    # Clarify callback pending
+    INTERRUPTED = "interrupted"      # User aborted
+    ERROR = "error"            # Unrecoverable error
+    DONE = "done"              # Completed successfully
+
+    @property
+    def is_terminal(self) -> bool:
+        """Terminal states — no further processing possible."""
+        return self in (AgentState.INTERRUPTED, AgentState.DONE, AgentState.ERROR)
+
+    @property
+    def is_active(self) -> bool:
+        """Agent is in a state where it could still produce output."""
+        return not self.is_terminal
+
+
+class AgentStatus:
+    """Snapshot of agent state queryable by parent agents.
+
+    Used for multi-agent coordination: parent checks child state before
+    forking plans, sending interrupts, or waiting for results.
+    """
+
+    __slots__ = (
+        "state",
+        "session_id",
+        "iteration_count",
+        "children_active",
+        "error_message",
+        "abort_reason",
+        "done_reason",
+    )
+
+    def __init__(
+        self,
+        state: AgentState,
+        session_id: str = "",
+        iteration_count: int = 0,
+        children_active: int = 0,
+        error_message: str = "",
+        abort_reason: str = "",
+        done_reason: str = "",
+    ):
+        self.state = state
+        self.session_id = session_id
+        self.iteration_count = iteration_count
+        self.children_active = children_active
+        self.error_message = error_message
+        self.abort_reason = abort_reason
+        self.done_reason = done_reason
+
+    def to_dict(self) -> dict:
+        return {
+            "state": self.state.value,
+            "session_id": self.session_id,
+            "iteration_count": self.iteration_count,
+            "children_active": self.children_active,
+            "error_message": self.error_message,
+            "abort_reason": self.abort_reason,
+            "done_reason": self.done_reason,
+        }
+
+    def __repr__(self) -> str:
+        return (
+            f"AgentStatus(state={self.state.value}, session={self.session_id}, "
+            f"iter={self.iteration_count}, children={self.children_active})"
+        )
+
+
+class SessionState:
+    """Lightweight state tracker for AIAgent.
+
+    Wraps existing flags (_interrupt_requested, _executing_tools, etc.)
+    and provides a single query point for parent agents. The main loop
+    continues to drive from the flags — this is a read-only layer for
+    coordination, not a driver replacement.
+
+    Integration points:
+      - agent_init.py: creates agent._session_state
+      - conversation_loop.py: updates state at lifecycle transitions
+            (start_run → RUNNING, tool batch → WAITING_TOOLS, etc.)
+      - delegate_tool.py: parent queries child.state for coordination
+      - run_agent.py: session.resume → reads last known state
+    """
+
+    __slots__ = (
+        "_agent_ref",   # Weak ref to owner agent (weakref.ref)
+        "_state",
+        "_lock",
+        "_error_message",
+        "_abort_reason",
+        "_done_reason",
+        "_session_id",
+        "_iteration_count",
+    )
+
+    def __init__(self, agent):
+        # Store a strong reference — we need to read state flags from agent.
+        # SessionState lifespan matches agent lifespan.
+        self._agent_ref = agent
+        self._state = AgentState.IDLE
+        self._lock = threading.RLock()
+        self._error_message = ""
+        self._abort_reason = ""
+        self._done_reason = ""
+        self._session_id = ""
+        self._iteration_count = 0
+
+    # ── State getter/setter ──────────────────────────────────────────
+
+    @property
+    def state(self) -> AgentState:
+        with self._lock:
+            return self._state
+
+    @state.setter
+    def state(self, new_state: AgentState):
+        with self._lock:
+            old = self._state
+            if old == new_state:
+                return
+            # Validate transition (non-strict: allow reset)
+            if old.is_terminal and not new_state.is_terminal:
+                # Terminal → non-terminal is allowed for agent reuse
+                # (e.g. gateway reuses agent objects across messages)
+                pass
+            self._state = new_state
+
+    # ── Convenience setters for main-loop integration ─────────────────
+
+    def set_running(self):
+        """Called at top of run_conversation() main loop entry."""
+        self.state = AgentState.RUNNING
+        self._iteration_count = 0
+
+    def set_waiting_tools(self):
+        """Called when tool batch starts executing."""
+        self.state = AgentState.WAITING_TOOLS
+
+    def set_compressing(self):
+        """Called when compression begins."""
+        self.state = AgentState.COMPRESSING
+
+    def set_waiting_user(self):
+        """Called when clarify callback is pending."""
+        self.state = AgentState.WAITING_USER
+
+    def set_interrupted(self, reason: str = ""):
+        """Called when user aborts the agent."""
+        self.state = AgentState.INTERRUPTED
+        self._abort_reason = reason or self._abort_reason
+
+    def set_error(self, message: str = "", reason: str = ""):
+        """Called on unrecoverable error."""
+        self.state = AgentState.ERROR
+        self._error_message = message or self._error_message
+        self._abort_reason = reason or self._abort_reason
+
+    def set_done(self, reason: str = ""):
+        """Called when agent completes normally."""
+        self.state = AgentState.DONE
+        self._done_reason = reason or self._done_reason
+
+    def bump_iteration(self):
+        """Increment iteration counter (call at top of each turn)."""
+        with self._lock:
+            self._iteration_count += 1
+
+    def set_session_id(self, sid: str):
+        self._session_id = sid
+
+    # ── Derived properties (read from agent flags) ───────────────────
+
+    @property
+    def is_terminal(self) -> bool:
+        return self._state.is_terminal
+
+    @property
+    def is_interrupted(self) -> bool:
+        return self._state == AgentState.INTERRUPTED
+
+    @property
+    def is_running(self) -> bool:
+        return self._state == AgentState.RUNNING
+
+    @property
+    def is_idle(self) -> bool:
+        return self._state == AgentState.IDLE
+
+    # ── Snapshot for parent query ─────────────────────────────────────
+
+    def snapshot(self) -> AgentStatus:
+        """Return a copy of current state safe for parent thread reading."""
+        agent = self._agent_ref
+        with self._lock:
+            children = len(getattr(agent, "_active_children", ()))
+            return AgentStatus(
+                state=self._state,
+                session_id=self._session_id,
+                iteration_count=self._iteration_count,
+                children_active=children,
+                error_message=self._error_message,
+                abort_reason=self._abort_reason,
+                done_reason=self._done_reason,
+            )
+
+    def __repr__(self) -> str:
+        return f"SessionState({self._state.value}, iter={self._iteration_count})"
