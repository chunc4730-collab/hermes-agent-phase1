+"""Token-aware budget management with auto-continuation.
+
+Parses natural-language budget directives from user messages
+(e.g. ``+500k``, ``use 2M tokens``) and auto-continues the
+conversation loop until the budget is exhausted or output
+diminishes below a threshold.
+
+Inspired by Claude Code's tokenBudget.ts / query/tokenBudget.ts.
+"""
+
+from __future__ import annotations
+
+import logging
+import re
+from dataclasses import dataclass
+from typing import Optional
+
+logger = logging.getLogger(__name__)
+
+# ── Budget parsing ──────────────────────────────────────────────────
+
+# Match +N at line start or end, with k/m/b suffix.  Uses \\b
+# (word boundary) instead of end-of-line anchor so directives like
+# "+500k do this" still parse when they appear inline.
+_SHORTHAND_RE = re.compile(
+    r"(?:^|\n)\s*\+(\d+(?:\.\d+)?)\s*([kmb])\b",
+    re.IGNORECASE,
+)
+# Match verbose: "use N tokens", "预算 N token", etc.
+_VERBOSE_RE = re.compile(
+    r"(?:use|spend|预算|消耗|分配)\s+(\d+(?:\.\d+)?)\s*([kmb万]?)\s*(?:token|tokens|个?token|万)?",
+    re.IGNORECASE,
+)
+
+_SUFFIX_MULTIPLIER = {"k": 1_000, "m": 1_000_000, "b": 1_000_000_000, "万": 10_000, "": 1}
+
+
+def parse_token_budget(text: str) -> Optional[int]:
+    """Extract a token budget directive from a user message.
+
+    Returns the budget in raw token count, or None if no directive found.
+    Supports: ``+500k``, ``+2m``, ``use 1M tokens``, ``预算 100k token``.
+    """
+    if not text:
+        return None
+
+    # Try shorthand first (more common, stricter pattern)
+    m = _SHORTHAND_RE.search(text)
+    if m:
+        value = float(m.group(1))
+        suffix = m.group(2).lower()
+        return int(value * _SUFFIX_MULTIPLIER.get(suffix, 1))
+
+    # Try verbose
+    m = _VERBOSE_RE.search(text)
+    if m:
+        value = float(m.group(1))
+        suffix = (m.group(2) or "").lower()
+        return int(value * _SUFFIX_MULTIPLIER.get(suffix, 1))
+
+    return None
+
+
+def remove_budget_directive(text: str) -> str:
+    """Strip the budget directive from a user message so it doesn't
+    appear as part of the task to the model."""
+    text = _SHORTHAND_RE.sub("", text).strip()
+    text = _VERBOSE_RE.sub("", text).strip()
+    return text
+
+
+# ── Budget tracker ──────────────────────────────────────────────────
+
+# Thresholds (matching Claude's constants)
+COMPLETION_THRESHOLD = 0.90   # stop at 90% of budget
+DIMINISH_DELTA = 500          # tokens — below this for 2 consecutive turns → stop
+DIMINISH_TURNS = 2            # consecutive low-delta turns before stopping
+MIN_CONTINUATIONS_BEFORE_DIMINISH = 3  # don't check diminish until 3+ continuations
+
+
+@dataclass
+class BudgetTracker:
+    """Per-conversation token budget state."""
+
+    budget: int                    # total token budget
+    used: int = 0                  # output tokens consumed so far
+    continuation_count: int = 0    # number of auto-continuations
+    last_turn_delta: int = 0       # tokens produced in the last turn
+    consecutive_low_delta: int = 0 # turns in a row with delta < threshold
+
+    def record_turn(self, turn_tokens: int) -> None:
+        """Record output tokens from a completed turn."""
+        self.used += turn_tokens
+        self.last_turn_delta = turn_tokens
+        self.continuation_count += 1
+
+    def should_continue(self) -> bool:
+        """Return True if the agent should auto-continue."""
+        if self.budget <= 0:
+            return False
+
+        pct = self.used / self.budget
+
+        # Below 90% → continue
+        if pct < COMPLETION_THRESHOLD:
+            # Check diminishing returns
+            if self.continuation_count >= MIN_CONTINUATIONS_BEFORE_DIMINISH:
+                if self.last_turn_delta < DIMINISH_DELTA:
+                    self.consecutive_low_delta += 1
+                else:
+                    self.consecutive_low_delta = 0
+
+                if self.consecutive_low_delta >= DIMINISH_TURNS:
+                    return False
+            return True
+
+        return False
+
+    def get_nudge(self) -> str:
+        """Build the auto-continuation nudge message."""
+        pct = int(self.used / self.budget * 100)
+        remaining = self.budget - self.used
+        return (
+            f"Stopped at {pct}% of token budget "
+            f"({self.used:,} / {self.budget:,} used, "
+            f"{remaining:,} remaining). "
+            "Keep working — do not summarize or stop early."
+        )
+
+    def get_completion_message(self) -> str:
+        """Build the budget-exhausted message."""
+        return (
+            f"Token budget reached: {self.used:,} / {self.budget:,} "
+            f"({int(self.used / self.budget * 100)}%)."
+        )
